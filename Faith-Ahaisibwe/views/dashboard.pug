doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title= title
        link(rel="stylesheet" href="/css/dashboard.css")
    body
        header.main-header
            div.header-logo
                svg.logo-icon(viewBox="0 0 24 24" fill="currentColor")
                    path(d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z")
                span.logo-text Videx
            
            a.add-video-btn(href="/add-video") Add Video

        main.dashboard-content
            section.videos-section
                h2.section-title Videos
                hr.section-divider
                
                div.video-grid
                    each video in videos
                        div.video-card
                            div.thumbnail(style=(video.thumbnail ? 'cursor: pointer;' : `background-color: ${video.color || '#ccc'}; cursor: pointer;`), onclick=`playVideo('${video.file}', '${video.thumbnail || ''}')`, role="button")
                                if video.thumbnail
                                    img(src=video.thumbnail, alt=video.title, style="width: 100%; height: 100%; object-fit: cover; display: block;")
                                else
                                    svg.play-icon(viewBox="0 0 24 24" fill="white" style="width: 40px; height: 40px; margin: auto;")
                                        path(d="M8 5v14l11-7z")
                            
                            div.video-info
                                div.text-details
                                    h3.video-title= video.title
                                    p.video-metadata #{video.views} . #{video.uploaded}
                                button.options-btn &#8942;

        div.video-modal(id="videoModal" style="display: none;")
            div.modal-content
                span.close(onclick="closeVideo()") &times;
                video(id="videoPlayer" controls style="width: 100%; max-height: 80vh;")

        style.
            .video-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000; align-items: center; justify-content: center; }
            .video-modal.show { display: flex; }
            .modal-content { position: relative; background: #000; padding: 20px; border-radius: 8px; max-width: 90%; max-height: 90vh; }
            .close { position: absolute; top: 10px; right: 20px; color: white; font-size: 28px; cursor: pointer; font-weight: bold; }
            .play-icon { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); pointer-events: none; }
        
        script.
            function playVideo(videoFile, thumbnailFile) {
                const modal = document.getElementById('videoModal');
                const player = document.getElementById('videoPlayer');
                if (videoFile) {
                    player.src = videoFile;
                    modal.classList.add('show');
                    player.play();
                }
            }
            function closeVideo() {
                const modal = document.getElementById('videoModal');
                const player = document.getElementById('videoPlayer');
                player.pause();
                modal.classList.remove('show');
            }
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') closeVideo();
            });