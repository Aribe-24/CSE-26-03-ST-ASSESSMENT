doctype html
html(lang="en")
  head
    title Videx Dashboard
    link(rel="stylesheet", href="/css/dashboard.css")
  body
    .nav-bar
      h1.logo Videx
      button(id="addVideoBtn", class="add-btn") Add Video
    
    .container
      h2 Videos
      .video-grid
        each video in videos
          .video-card
            .thumbnail(style=`background-color: ${video.color || '#ccc'}`)
            .info
              h3= video.title
              p.meta= `${video.views} views . ${video.time}`

    script.
      // Redirect to upload page when "Add Video" is clicked
      document.getElementById('addVideoBtn').addEventListener('click', function() {
        window.location.href = '/upload';
      });