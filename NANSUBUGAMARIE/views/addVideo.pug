doctype html

html

    head

        title Upload Video

        link(
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            rel="stylesheet"
        )

    body

        .container.mt-4

            a.btn.btn-secondary.mb-3(
                href="/videos"
            )
                | ← Back

            h2 Upload Your Video

            form(
                id="videoForm"
                action="/videos/add"
                method="POST"
                enctype="multipart/form-data"
                novalidate
            )

                .mb-3

                    label.form-label Title

                    input.form-control(
                        type="text"
                        name="title"
                        required
                    )

                    .invalid-feedback

                        | Required field

                .mb-3

                    label.form-label Description

                    textarea.form-control(
                        name="description"
                        rows="3"
                        required
                    )

                    .invalid-feedback

                        | Required field

                .mb-3

                    label.form-label Quality

                    select.form-select(
                        name="quality"
                        required
                    )

                        option(value="") Select Quality

                        option(value="360p") 360p

                        option(value="720p") 720p

                        option(value="1080p") 1080p

                    .invalid-feedback

                        | Required field

                .mb-3

                    label.form-label Upload Video

                    input.form-control(
                        type="file"
                        name="video"
                        id="videoInput"
                        required
                    )

                    .invalid-feedback

                        | Required field

                video#videoPreview.w-100.mb-3(
                    controls
                    style="display:none;height:300px"
                )

                .mb-3

                    label.form-label Upload Thumbnail

                    input.form-control(
                        type="file"
                        name="thumbnail"
                        id="thumbnailInput"
                        required
                    )

                    .invalid-feedback

                        | Required field

                img#thumbnailPreview(
                    style="display:none;width:250px;height:250px;object-fit:cover"
                )

                br
                br

                button.btn.btn-danger(
                    type="submit"
                )
                    | Upload Video

                button.btn.btn-secondary.ms-2(
                    type="reset"
                )
                    | Reset
    
