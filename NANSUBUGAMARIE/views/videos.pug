doctype html

html

    head

        title Videos

        link(
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            rel="stylesheet"
        )

    body

        .container.mt-4

            .d-flex.justify-content-between.mb-4

                h2 Videos

                a.btn.btn-danger(
                    href="/videos/add"
                ) Add Video

            if videos.length === 0

                .alert.alert-info

                    | No videos uploaded

            else

                .row

                    each video in videos

                        .col-md-4.mb-4

                            .card

                                img.card-img-top(
                                    src="/uploads/thumbnails/" + video.thumbnail
                                    style="height:250px;object-fit:cover"
                                )

                                .card-body

                                    h5.card-title

                                        = video.title

                                    p.card-text

                                        = video.description

                                    p

                                        strong Quality:

                                        | #{video.quality}

                                    video.w-100(
                                        controls
                                    )

                                        source(
                                            src="/uploads/videos/" + video.video
                                            type="video/mp4"
                                        )