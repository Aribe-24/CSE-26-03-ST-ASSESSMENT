extends ../layout

block content
  .app-layout
    header.app-header
      a.header-logo(href="/videos")
        svg(viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" width="36" height="36")
          circle(cx="30" cy="30" r="30" fill="red")
          polygon(points="24,18 24,42 46,30" fill="white")
        span Videx
      a.add-video-btn(href="/videos/upload") Add Video

    main.main-content
      h2.section-title Videos
      .section-divider

      if videos && videos.length
        .videos-grid
          each video in videos
            .video-card
              a(href=`/videos/${video._id}`)
                .video-thumb
                  if video.thumbnail
                    img(src=`/${video.thumbnail}` alt=video.title)
                  else
                    .thumb-placeholder
                  .thumb-overlay
                    svg(viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" width="40" height="40")
                      circle(cx="30" cy="30" r="30" fill="rgba(0,0,0,0.5)")
                      polygon(points="24,18 24,42 46,30" fill="white")
              .video-info
                .video-meta-row
                  p.video-title= video.title
                  button.more-btn(type="button" aria-label="More options")
                    svg(viewBox="0 0 24 24" width="18" height="18" fill="currentColor")
                      circle(cx="12" cy="5" r="1.5")
                      circle(cx="12" cy="12" r="1.5")
                      circle(cx="12" cy="19" r="1.5")
                .video-stats #{video.viewsFormatted} views · #{video.timeAgo}
      else
        .empty-state
          p No videos yet. #[a(href="/videos/upload") Upload the first one!]