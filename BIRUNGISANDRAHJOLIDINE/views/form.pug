doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Upload Your Video
    link(rel="stylesheet" href="/css/form.css")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
    link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Helvetica+Neue:wght@400;500;700&display=swap")
  body
    main.form-wrapper
      h1.form-title Upload your video
      
      form.upload-form(method="post" action="/upload" enctype="multipart/form-data")
        .form-left
          .input-group
            input(type="text" name="title" placeholder="Video Title" required)
          
          .input-group
            textarea(name="description" placeholder="Description (Optional)" rows="6")
          
          .input-group.select-wrapper
            select(name="quality" required)
              option(value="" disabled selected hidden) Video quality
              option(value="1080p") 1080p (Full HD)
              option(value="720p") 720p (HD)
              option(value="480p") 480p
            i.fa-solid.fa-chevron-down.select-icon
          
          .input-group.date-wrapper
            input(type="text" name="publishDate" placeholder="Date of Publishing" onfocus="(this.type='date')" onblur="(this.type='text')")
            i.fa-solid.fa-calendar-days.date-ico
        .form-right
          label.upload-box.video-dropzone
            input(type="file" name="video" accept="video/*" hidden required)
            i.fa-solid.fa-cloud-arrow-up.upload-icon
            span Upload video
          
          label.upload-box.thumbnail-dropzone
            input(type="file" name="thumbnail" accept="image/*" hidden)
            i.fa-solid.fa-cloud-arrow-up.upload-icon
            span Upload Thumbnail
          
          button.submit-btn(type="submit") UPLOAD
