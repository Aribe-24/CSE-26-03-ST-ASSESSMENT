doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Upload Your Video
    link(rel="stylesheet" href="/css/form.css")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
    link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Helvetica+Neue:wght@400;500;700&display=swap")
  body
    main.form-wrapper
      .success-message Video successfully uploaded
      
      h1.form-title Upload your video
      
      form.upload-form(method="post" action="/upload" enctype="multipart/form-data" novalidate)
        .form-left
          .input-group
            input(type="text" name="title" placeholder="Video Title" required)
            span.error-message
          
          .input-group
            textarea(name="description" placeholder="Description (Optional)" rows="6")
            span.error-message
          
          .input-group.select-wrapper
            select(name="quality" required)
              option(value="" disabled selected hidden) Video quality
              option(value="1080p") 1080p (Full HD)
              option(value="720p") 720p (HD)
              option(value="480p") 480p
            i.fa-solid.fa-chevron-down.select-icon
            span.error-message
          
          .input-group.date-wrapper
            input(type="text" name="publishDate" placeholder="Date of Publishing" onfocus="(this.type='date')" onblur="(this.type='text')")
            i.fa-solid.fa-calendar-days.date-ico
            span.error-message
        .form-right
          label.upload-box.video-dropzone
            input(type="file" name="video" accept="video/*" hidden required)
            i.fa-solid.fa-cloud-arrow-up.upload-icon
            span Upload video
            span.error-message
          
          label.upload-box.thumbnail-dropzone
            input(type="file" name="thumbnail" accept="image/*" hidden)
            i.fa-solid.fa-cloud-arrow-up.upload-icon
            span Upload Thumbnail
            span.error-message
          
          button.submit-btn(type="submit") UPLOAD
        script.
          const form = document.querySelector(".upload-form");
          const inputs = form.querySelectorAll("input, textarea, select");

          form.addEventListener("submit", (e) => {
              let hasError = false;

              inputs.forEach((input) => {
              const box = input.closest(".input-group, .upload-box");
              if (!box) return;

              const errorMsg = box.querySelector(".error-message");
              let isEmpty = false;

              if (input.type === "file") {
                  isEmpty = input.files.length === 0;
              }

              else if (input.tagName === "SELECT") {
                  isEmpty = input.value === "";
              }

              else {
                  isEmpty = input.value.trim() === "";
              }

              if (input.hasAttribute("required") && isEmpty) {
                  box.classList.add("error");
                  if (errorMsg) {
                      errorMsg.textContent = "This field is required.";
                  }
                  hasError = true;
              } else {
                  box.classList.remove("error");
                  if (errorMsg) {
                      errorMsg.textContent = "";
                  }
              }
              });

              if (hasError) {
              e.preventDefault();
              }
          });